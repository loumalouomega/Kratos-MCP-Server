    "default_condition": "ThermalFace2D2N",
    "placeholders": {
      "problem_name": "case",
      "domain_size": 2,
      "end_time": 1.0,
      "time_step": 0.1,
      "mdpa_basename": "mesh",
      "materials_filename": "Materials.json",
      "domain_parts": [
        "domain"
      ],
      "boundary_parts": [
        "left",
        "right"
      ],
      "fix_model_part": "ThermalModelPart.left",
      "fixed_temperature": 100.0,
      "material_model_part": "ThermalModelPart.domain",
      "density": 7850.0,
      "conductivity": 15.0,
      "specific_heat": 500.0,
      "output_path": "vtk_output",
      "nodal_results": [
        "TEMPERATURE",
        "REACTION_FLUX"
      ]
    }
  },
