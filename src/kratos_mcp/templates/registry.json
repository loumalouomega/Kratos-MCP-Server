  "thermal_transient": {
    "description": "Transient heat conduction / convection-diffusion analysis",
    "analysis_type": "thermal",
    "model_part_name": "ThermalModelPart",
    "required_applications": [
      "ConvectionDiffusionApplication",
      "LinearSolversApplication"
    ],
    "solver_module": "KratosMultiphysics.ConvectionDiffusionApplication.convection_diffusion_transient_solver",
